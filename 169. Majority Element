class Solution {
public:
    int majorityElement(vector<int>& nums) {
        sort(nums.begin(), nums.end());
        
        int size = nums.size();
        int bestElement = nums[0];
        int bestCount = 1;
        int count = 1;

        for (int i = 1; i < size; i++) {
            if (nums[i] == nums[i - 1]) {
                count++;
            } else {
                count = 1;
            }

            if (count > bestCount) {
                bestCount = count;
                bestElement = nums[i];
            }
        }

        return bestElement;
    }
};
