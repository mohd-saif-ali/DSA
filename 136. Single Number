class Solution {
public:
    int singleNumber(vector<int>& nums) {
        int size=nums.size();
        sort(nums.begin() , nums.end());
        int count=1;
        int res=-22;
        for(int i=0 ;i<size-1;i++)
        {
            if(nums[i]==nums[i+1])
            {
                count++;
            }
            else{
                if(count>1)
                count=1;
                else{
                res=nums[i];
                break;
                }


            }

        }
        if(res==-22)
        {
            return nums[size-1];
        
        }
        else 
        return res;
    }
};
